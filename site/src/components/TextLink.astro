---
interface Props {
  href: string;
  arrow?: boolean;
}

const { href, arrow = false } = Astro.props;
---

<a class="text-link" href={href}>
  <span><slot /></span>
  {arrow && (
    <svg class="text-link-arrow" viewBox="0 0 16 16" aria-hidden="true">
      <path
        d="M3 8h8M8 3l5 5-5 5"
        fill="none"
        stroke="currentColor"
        stroke-linecap="square"
        stroke-linejoin="miter"
        stroke-width="1.4"
      />
    </svg>
  )}
</a>

<style>
  .text-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.1;
    text-decoration: none;
  }

  .text-link:hover,
  .text-link:focus-visible {
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .text-link:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--accent) 42%, transparent);
    outline-offset: 3px;
  }

  .text-link-arrow {
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
  }
</style>
