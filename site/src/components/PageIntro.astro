---
interface Props {
  title: string;
  lead?: string;
  noWrapTitle?: boolean;
}

const { title, lead, noWrapTitle = false } = Astro.props;
---

<section class="page-intro">
  <h1
    class="page-intro-title"
    style={noWrapTitle ? "max-width:none;white-space:nowrap;" : undefined}
  >
    {title}
  </h1>
  {lead && <p class="page-intro-lead">{lead}</p>}
</section>

<style>
  .page-intro {
    display: grid;
    gap: 24px;
    padding: 40px 0 10px;
  }

  .page-intro-title {
    margin: 0;
    max-width: 10ch;
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 0.9;
    letter-spacing: 0;
  }

  .page-intro-lead {
    margin: 0;
    max-width: 40rem;
    color: var(--muted);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .page-intro {
      gap: 16px;
      padding: 30px 0 2px;
    }

    .page-intro-title {
      max-width: none;
      font-size: clamp(1.8rem, 9vw, 2.45rem);
      line-height: 0.94;
    }

    .page-intro-lead {
      font-size: 1rem;
      line-height: 1.48;
    }
  }
</style>
