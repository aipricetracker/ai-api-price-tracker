---
interface Props {
  name: "current" | "history" | "static";
}

const { name } = Astro.props;
---

<span class="summary-icon" aria-hidden="true">
  {name === "current" && (
    <svg viewBox="0 0 48 48" role="img">
      <rect x="9" y="11" width="30" height="26" rx="0" />
      <path d="M9 17h30" />
      <path d="M15 23h12" />
      <path d="M15 29h18" />
      <path d="M30 9v6" />
      <path d="M36 9v6" />
      <path d="M31 33h5" />
      <path d="M34 30v6" />
    </svg>
  )}
  {name === "history" && (
    <svg viewBox="0 0 48 48" role="img">
      <path d="M24 8v32" />
      <circle cx="24" cy="13" r="3.5" />
      <circle cx="24" cy="24" r="3.5" />
      <circle cx="24" cy="35" r="3.5" />
      <path d="M12 13h8" />
      <path d="M28 24h8" />
      <path d="M12 35h8" />
      <path d="M36 18l-4 6 4 6" />
      <path d="M32 24h7" />
    </svg>
  )}
  {name === "static" && (
    <svg viewBox="0 0 48 48" role="img">
      <rect x="10" y="13" width="28" height="22" rx="0" />
      <path d="M10 19h28" />
      <path d="M16 25h16" />
      <path d="M16 30h10" />
      <path d="M17 9h14" />
      <path d="M17 39h14" />
      <path d="M33 25l4 3-4 3" />
      <path d="M37 28h-8" />
    </svg>
  )}
</span>

<style>
  .summary-icon {
    display: inline-flex;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--accent) 88%, var(--ink));
  }

  .summary-icon svg {
    width: 48px;
    height: 48px;
    fill: none;
    stroke: currentColor;
    stroke-linecap: square;
    stroke-linejoin: miter;
    stroke-width: 1.5;
  }
</style>
