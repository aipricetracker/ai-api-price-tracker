---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDateShort, getProviderOverviewList } from "../../lib/data";
import { text } from "../../lib/ui-text";

const providers = await getProviderOverviewList();
---

<BaseLayout title={text.providers} description={text.providersMetaDescription}>
  <section class="card">
    <p class="eyebrow">{text.providerIndex}</p>
    <p class="muted">{text.providerIndexDescription}</p>
    <p class="muted">{text.providerIndexColumnsDescription}</p>
  </section>

  <section class="card">
    <table>
      <thead>
        <tr>
          <th>{text.providerColumn}</th>
          <th>{text.modelsColumn}</th>
          <th>{text.totalChangesColumn}</th>
          <th>{text.latestChangeColumn}</th>
          <th>{text.detailColumn}</th>
        </tr>
      </thead>
      <tbody>
        {providers.map((provider) => (
          <tr>
            <td data-label={text.providerDataLabel}>
              <a href={`/providers/${provider.provider}`}>{provider.provider}</a>
            </td>
            <td data-label={text.modelsDataLabel}>{provider.modelCount}</td>
            <td data-label={text.totalChangesDataLabel}>{provider.recentChangeCount}</td>
            <td data-label={text.latestChangeDataLabel}>{formatDateShort(provider.latestUpdate)}</td>
            <td data-label={text.detailDataLabel}>
              <a href={`/providers/${provider.provider}`}>{text.viewProvider}</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
