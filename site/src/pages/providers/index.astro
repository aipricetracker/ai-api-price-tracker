---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageIntro from "../../components/PageIntro.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import TextLink from "../../components/TextLink.astro";
import { formatDateShort, getProviderOverviewList } from "../../lib/data";
import { text } from "../../lib/ui-text";

const providers = await getProviderOverviewList();
---

<BaseLayout
  title={text.providers}
  description={text.providersMetaDescription}
  headerTitle=""
  mainGap="56px"
>
  <PageIntro title={text.providers} lead={text.providersPageDescription} />

  <section class="providers-page">
    <SectionHeading
      title={text.providerIndex}
      lead={`${text.providerIndexDescription} ${text.providerIndexColumnsDescription}`}
    />

    <div class="providers-grid">
      <div class="provider-row provider-row-head" aria-hidden="true">
        <span>{text.providerColumn}</span>
        <span>{text.modelsColumn}</span>
        <span>{text.totalChangesColumn}</span>
        <span>{text.latestChangeColumn}</span>
        <span>{text.detailColumn}</span>
      </div>

      {providers.map((provider) => (
        <article class="provider-row">
          <h2 class="provider-name">
            <a href={`/providers/${provider.provider}`}>{provider.provider}</a>
          </h2>

          <div class="provider-cell">
            <p class="provider-cell-label">{text.modelsColumn}</p>
            <p class="provider-cell-value">{provider.modelCount}</p>
          </div>

          <div class="provider-cell">
            <p class="provider-cell-label">{text.totalChangesColumn}</p>
            <p class="provider-cell-value">{provider.recentChangeCount}</p>
          </div>

          <div class="provider-cell">
            <p class="provider-cell-label">{text.latestChangeColumn}</p>
            <p class="provider-cell-value">{formatDateShort(provider.latestUpdate)}</p>
          </div>

          <div class="provider-action">
            <TextLink href={`/providers/${provider.provider}`} arrow={true}>
              {text.viewProvider}
            </TextLink>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .providers-page {
    display: grid;
    gap: 20px;
  }

  .providers-grid {
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line-strong);
  }

  .provider-row {
    display: grid;
    grid-template-columns:
      minmax(10rem, 1.22fr)
      minmax(6rem, 0.72fr)
      minmax(8.25rem, 0.72fr)
      minmax(9.5rem, 0.82fr)
      minmax(8.25rem, 0.72fr);
    gap: 22px;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
  }

  .provider-row-head {
    padding: 10px 0 9px;
    border-bottom-color: var(--line-strong);
  }

  .provider-row-head span {
    display: block;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.66rem;
  }

  .provider-name {
    margin: 0;
    font-size: clamp(1.24rem, 2.5vw, 1.7rem);
    line-height: 0.96;
  }

  .provider-name a {
    color: inherit;
    text-decoration: none;
  }

  .provider-name a:hover {
    text-decoration: underline;
  }

  .provider-cell {
    display: grid;
    gap: 5px;
    justify-items: start;
  }

  .provider-cell-label {
    display: none;
    margin: 0;
    color: var(--muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .provider-cell-value {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.12;
  }

  .provider-action {
    display: flex;
    justify-content: flex-start;
  }

  @media (max-width: 900px) {
    .provider-row {
      grid-template-columns: minmax(0, 1fr) repeat(2, minmax(0, 0.65fr));
      align-items: start;
    }

    .provider-row-head {
      display: none;
    }

    .provider-name {
      grid-column: 1 / -1;
    }

    .provider-cell-label {
      display: block;
    }

    .provider-action {
      grid-column: 1 / -1;
      justify-content: start;
      padding-top: 6px;
    }
  }

  @media (max-width: 640px) {
    .provider-row {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 16px 12px 18px;
    }

    .provider-name,
    .provider-action {
      grid-column: auto;
    }

    .provider-name {
      margin-bottom: 8px;
    }

    .provider-cell {
      gap: 2px;
    }

    .provider-cell-label {
      font-size: 0.58rem;
      letter-spacing: 0.14em;
    }

    .provider-cell-value {
      font-size: 1rem;
    }

    .provider-action {
      padding-top: 2px;
    }
  }
</style>
