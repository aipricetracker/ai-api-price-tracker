---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatPrice, getProviderModelList, getProviderSlugs } from "../../lib/data";
import { text } from "../../lib/ui-text";

export async function getStaticPaths() {
  const providers = await getProviderSlugs();
  return providers.map((provider) => ({ params: { provider } }));
}

const provider = Astro.params.provider ?? "";
const models = await getProviderModelList(provider);

if (models.length < 1) {
  return Astro.redirect("/providers");
}

const cachedInputNote = models.find((model) => model.cachedInputNote)?.cachedInputNote;
---

<BaseLayout
  title={`${provider} ${text.pricingTitleSuffix}`}
  description={`${text.currentSnapshotMetaDescriptionPrefix} ${provider}.`}
>
  <section class="card">
    <p class="eyebrow">{text.currentSnapshot}</p>
    <p class="muted">{models.length} {text.currentSnapshotCountSuffix}</p>
    {cachedInputNote && <p class="note">{cachedInputNote}</p>}
  </section>

  <section class="card">
    <table>
      <thead>
        <tr>
          <th>{text.modelColumn}</th>
          <th>{text.inputColumn}</th>
          <th>{text.cachedInputColumn}</th>
          <th>{text.outputColumn}</th>
          <th>{text.historyColumn}</th>
        </tr>
      </thead>
      <tbody>
        {models.map((model) => (
          <tr>
            <td data-label={text.modelDataLabel}>{model.model}</td>
            <td data-label={text.inputDataLabel}>{formatPrice(model.pricing.input)}</td>
            <td data-label={text.cachedInputDataLabel}>{formatPrice(model.pricing.cached_input)}</td>
            <td data-label={text.outputDataLabel}>{formatPrice(model.pricing.output)}</td>
            <td data-label={text.historyDataLabel}>
              <a href={`/providers/${provider}/${model.model}`}>{text.historyView}</a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>
</BaseLayout>
