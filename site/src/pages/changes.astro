---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageIntro from "../components/PageIntro.astro";
import SectionHeading from "../components/SectionHeading.astro";
import {
  formatRecentChangeDate,
  getAllChanges,
  summarizeChangedFields,
} from "../lib/data";
import { text } from "../lib/ui-text";

const changes = await getAllChanges();
---

<BaseLayout title={text.changesPageTitle} description={text.changesMetaDescription} headerTitle="" mainGap="56px">
  <PageIntro title={text.changes} lead={text.changesPageDescription} />
  <section class="changes-page">
    <style>
      .changes-page {
        display: grid;
        gap: 22px;
      }

      .changes-list {
        display: grid;
        gap: 0;
      }

      .change-item {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(0, 1fr);
        gap: 20px;
        padding: 26px 0 24px;
        border-top: 1px solid var(--line-strong);
      }

      .change-item:last-child {
        border-bottom: 1px solid var(--line);
      }

      .change-main {
        display: grid;
        gap: 10px;
      }

      .change-title {
        margin: 0;
        font-size: clamp(1.7rem, 3vw, 2.5rem);
        line-height: 0.98;
      }

      .change-title a {
        color: inherit;
        text-decoration: none;
      }

      .change-title a:hover {
        text-decoration: underline;
      }

      .change-summary {
        margin: 0;
        color: var(--ink);
        font-weight: 700;
        font-size: 1.05rem;
      }

      .change-meta {
        margin: 0;
        color: var(--accent);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .change-diffs {
        display: grid;
        gap: 14px;
        padding-left: 40px;
        border-left: 1px solid color-mix(in srgb, var(--line-strong) 82%, white);
      }

      .change-diff {
        display: grid;
        gap: 6px;
        padding: 2px 0 10px;
        border-bottom: 1px solid color-mix(in srgb, var(--line) 76%, white);
      }

      .change-diff:last-child {
        padding-bottom: 0;
        border-bottom: 0;
      }

      .change-diff-label {
        margin: 0;
        color: var(--accent);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.72rem;
      }

      .change-diff-value {
        margin: 0;
        font-size: 1.3rem;
        line-height: 1.08;
      }

      .change-diff-rate {
        margin: 0;
        color: var(--muted);
        font-size: 0.96rem;
      }

      @media (max-width: 820px) {
        .change-item {
          grid-template-columns: 1fr;
        }

        .change-diffs {
          padding-left: 0;
          border-left: 0;
        }
      }

      @media (max-width: 560px) {
        .change-item {
          gap: 14px;
          padding: 22px 0 20px;
        }

        .change-title {
          font-size: clamp(1.45rem, 7vw, 2rem);
        }

        .change-diff-value {
          font-size: 1.15rem;
        }
      }
    </style>
    <SectionHeading title={text.allChangeEvents} />
    <div class="changes-list">
      {changes.map((entry) => (
        <article class="change-item">
          <div class="change-main">
            <p class="change-meta">{formatRecentChangeDate(entry.record.recorded_at, entry.record.effective_date)}</p>
            <h2 class="change-title">
              <a href={`/providers/${entry.record.provider}/${entry.record.model}`}>
                {entry.record.provider} / {entry.record.model}
              </a>
            </h2>
            <p class="change-summary">{summarizeChangedFields(entry.changedFields)}</p>
          </div>
          <div class="change-diffs">
            {entry.fieldDiffs.map((diff) => (
              <div class="change-diff">
                <p class="change-diff-label">{diff.label}</p>
                <p class="change-diff-value">{diff.before} → {diff.after}</p>
                {diff.changeRate && <p class="change-diff-rate">{diff.changeRate}</p>}
              </div>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
